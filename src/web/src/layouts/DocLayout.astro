---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Kayoko</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400&family=JetBrains+Mono:wght@300&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col md:flex-row">
    
    <aside class="w-full md:w-72 p-12 md:sticky md:top-0 md:h-screen bg-kayoko-accent/5">
      <div class="mb-16">
        <h1 class="text-2xl font-light tracking-tighter mb-1">Kayoko</h1>
        <p class="text-[11px] font-normal text-kayoko-muted uppercase tracking-[0.25em]">A secure, Unix-like OS</p>
      </div>
      
      <nav>
        <ul class="space-y-4 text-[13px] font-normal tracking-wide text-kayoko-text/70 !list-none !ml-0">
	<li><a href="https://github.com/kayoko-org/src" class="hover:text-black transition-colors">GitHub</a></li>
          <li><a href="/" class="hover:text-black transition-colors">Overview</a></li>
          <li><a href="/docs/build" class="hover:text-black transition-colors">Build System</a></li>
        </ul>
      </nav>
    </aside>

    <main class="flex-1 p-12 md:p-24 lg:p-32 max-w-6xl bg-white">
      <header class="mb-20">
        <h2 class="text-5xl md:text-6xl font-extralight text-black leading-tight">{title}</h2>
      </header>

      <article class="prose prose-neutral max-w-none 
        prose-p:font-light prose-p:leading-[2.2] prose-p:mb-10 prose-p:text-kayoko-text/80
        prose-li:marker:text-black
        prose-a:decoration-kayoko-accent prose-a:underline-offset-8 prose-a:decoration-2
        prose-pre:bg-kayoko-bg prose-pre:border prose-pre:border-kayoko-border prose-pre:rounded-none
        prose-code:bg-kayoko-accent/40 prose-code:font-light prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-sm">
        <slot />
      </article>

      <footer class="mt-40 pt-10 border-t border-kayoko-border">
        <p class="text-[9px] uppercase tracking-[0.5em] text-kayoko-muted font-extralight">
          Obsessively crafted in Neovim // Kayoko Project
        </p>
      </footer>
    </main>
  </body>
</html>
