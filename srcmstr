#!/bin/ksh
# XAI System Resource Controller - Execution Phase
# Strict check: Only allow PID 1 (init) to run this
if [ "$$" -ne 1 ]; then
    print "error: srcmstr must be run as PID 1." >&2
    exit 1
fi

# 1. Real Setup (Using sbase mount)
/bin/mount -t proc proc /proc
/bin/mount -t sysfs sys /sys
/bin/mount -t devtmpfs dev /dev 2>/dev/null

# 2. Identity Check (Using your compiled uname and libkstat)
export LD_PRELOAD=/lib/libkstat.so
SYS_NAME=$(/bin/uname -s)
SYS_VER=$(/bin/uname -v)

# 3. Output logic based on your os-release and lppcfg
if [ -f /etc/os-release ]; then
    . /etc/os-release
    print "Starting $NAME $VERSION..."
fi

# 4. Starting the Sync Daemon (Real sbase sync)
/bin/sync &
print "0513-059 The sync Subsystem has been started. Subsystem PID is $!."

# 5. Load Kernel Tables (Using the lppcfg you created)
if [ -f /etc/lppcfg ]; then
    while read -r line; do
        case "$line" in
            "#"*) continue ;;
            *) print "Successfully updated the Kernel ${line%%:*} Table." ;;
        esac
    done < /etc/lppcfg
fi

print "System runtime mode is now OPERATIONAL MODE."

# 6. Multi-user Mounts (Real sbase mount -a)
print "Performing all automatic mounts"
/bin/mount -a 2>/dev/null

# 7. Final Handover
print "Multi-user initialization completed"
print "Checking for srcmstr active...complete"
print "$NAME Version $VERSION_ID"
/sbin/login || /bin/ksh || /bin/oksh || /bin/sh || /sbin/login && /sbin/login || echo '! ! Missing login device ! !' && exit 1

while true; do
    wait
done
