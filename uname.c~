#include <stdio.h>
#include <unistd.h>
#include <sys/utsname.h>
#include <string.h>

/* Helper to handle the space-separated output format required by POSIX */
void print_tag(char *data, int *first) {
    if (!*first) putchar(' ');
    fputs(data, stdout);
    *first = 0;
}

int main(int argc, char *argv[]) {
    struct utsname s;
    int c, first = 1;
    int aflag=0, sflag=0, nflag=0, rflag=0, vflag=0, mflag=0;

    /* POSIX ONLY: -a, -s, -n, -r, -v, -m */
    /* Any other flag (like -o) triggers the default case */
    while ((c = getopt(argc, argv, "asnrvm")) != -1) {
        switch (c) {
            case 'a': aflag = 1; break;
            case 's': sflag = 1; break;
            case 'n': nflag = 1; break;
            case 'r': rflag = 1; break;
            case 'v': vflag = 1; break;
            case 'm': mflag = 1; break;
            default: 
                /* ERROR ACTION: POSIX requires a diagnostic message to stderr 
                   and a non-zero exit status for invalid options. */
                fprintf(stderr, "usage: uname [-asnrvm]\n");
                return 1;
        }
    }

    if (uname(&s) < 0) {
        fprintf(stderr, "uname: system call failed\n");
        return 1;
    }

    /* If no options, default to -s */
    if (optind == argc && !aflag) sflag = 1;

    if (aflag || sflag) print_tag(s.sysname,  &first);
    if (aflag || nflag) print_tag(s.nodename, &first);
    if (aflag || rflag) print_tag(s.release,  &first);
    if (aflag || vflag) print_tag(s.version,  &first);
    if (aflag || mflag) print_tag(s.machine,  &first);

    putchar('\n');
    return 0;
}
