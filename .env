#!/bin/ksh
# Configuration

# 1. Base Paths
export XAO_ROOT="$(pwd)/root"
export OBJ_DIR="$XAO_ROOT/obj"
export TOOL_DIR="$XAO_ROOT/tools"
export _INST="$(pwd)/inst"

# 2. Source & Build Deps
export OKSH_DIR="/tmp/xao/oksh"
export NBSD_SRC="/usr/netbsd/src"

# 3. System Metadata
export ARCH=$(machine)
export _VER="1.2.5"
export NPROCS=$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)

# 5. Generated Artifacts (Defined last so OBJ_DIR is set)
_TS=$(date +%Y%m%d-%H%M)
export USB_IMG="$OBJ_DIR/xao-$_TS.usb"
export CDROM_IMG="$OBJ_DIR/xao-$_TS.iso"
