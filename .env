#!/bin/ksh
# Configuration
export XAI_ROOT="$(pwd)/root"
export SBASE_DIR="/tmp/xai/sbase"
export OKSH_DIR="/tmp/xai/oksh"
export NBSD_SRC="/usr/netbsd/src"
export OBJ_DIR="$XAI_ROOT/obj"
export TOOL_DIR="$XAI_ROOT/tools"
export ARCH=$(machine)
export _VER="1.2.5"
export AUTOCONF_VERSION=2.64
export AUTOMAKE_VERSION=2.64
export M4_VERSION=2.64
export _INST="$(pwd)/inst"
# 0. POSIX check for parallelism
# Replaces GNU 'nproc'
export NPROCS=$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)
